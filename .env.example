# ================================
# 内容发布平台 - 环境变量配置
# ================================

# ----- 数据库配置 -----
POSTGRES_PASSWORD=postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:54321/chujiang?schema=cpp"

# ----- Redis 配置 -----
REDIS_URL="redis://halfthin:change-me@localhost:16378/0"

# ----- Cookie 加密配置 (生产环境必须修改!) -----
COOKIE_ENCRYPTION_KEY="your-32-char-secret-key-here!!!"
COOKIE_ENCRYPTION_SALT="random-salt-string"

# ----- 服务器配置 -----
PORT=50000
NODE_ENV=development

# ----- WebSocket 配置 -----
WS_HEARTBEAT_INTERVAL=30000
AUTH_TIMEOUT=900000

# ----- 内容目录 -----
CONTENT_DIR="./content"
MEDIA_ROOT_DAPAI="/mnt/dapai-s"

# ----- 素材动作转发配置（按需启用） -----
# 默认会复用下面的 OPENCLAW / CPP Gateway 配置；如需单独路由可再覆盖这些 MEDIA_ACTION_* 变量
MEDIA_ACTION_GATEWAY_URL=""
MEDIA_ACTION_TO_GATEWAY_TOKEN=""
MEDIA_ACTION_FROM_GATEWAY_TOKEN=""
MEDIA_ACTION_GATEWAY_ROUTE_PREFIX="/webhooks/cpp/media-actions"
MEDIA_ACTION_IMAGE_TO_IMAGE_DISPATCH_PATH="/webhooks/cpp/oc/vd-shoot"

# ----- 通用 Gateway 配置（内容发布 / 素材动作都可复用） -----
OPENCLAW_GATEWAY_URL="http://localhost:18789"
CPP_TO_GATEWAY_TOKEN=""
CPP_FROM_GATEWAY_TOKEN=""
PUBLISH_MODE="gateway"
API_BASE_URL="http://localhost:3000"

# ----- 日志级别 -----
LOG_LEVEL="debug"

# ----- Playwright 配置 -----
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOW_MO=100

# ----- Xiaohongshu MCP 直连配置 -----
# JSON 数组，每个元素包含 name 和 url，一个实例对应一个小红书账号
# XHS_MCP_INSTANCES=[{"name":"xhs-1","url":"http://100.64.0.11:5601"}]
