# ----- 数据库配置 -----
# 使用本机 PostgreSQL：chujiang 数据库 / cpp schema
POSTGRES_PASSWORD=Bing!15706668163
DATABASE_URL="postgresql://postgres:Bing!15706668163@localhost:54321/chujiang?schema=cpp"

# ----- Redis 配置 -----
# 使用本机 Redis
REDIS_PASSWORD=Bing999999999
REDIS_URL="redis://halfthin:Bing999999999@localhost:16378/0"

# ----- Cookie 加密配置 (生产环境必须修改!) -----
