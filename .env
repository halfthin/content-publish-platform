# ----- 服务器配置 -----
PORT=50000
NODE_ENV=development

# ----- WebSocket 配置 -----
WS_HEARTBEAT_INTERVAL=30000
AUTH_TIMEOUT=900000

# ----- 内容目录 -----
CONTENT_DIR="./content"

# ----- 日志级别 -----
LOG_LEVEL="debug"

# ----- Playwright 配置 -----
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOW_MO=100
