# ================================
# 内容发布平台 - 环境变量配置
# ================================

# ----- 数据库配置 -----
# 使用外部 PostgreSQL（已独立部署）
POSTGRES_PASSWORD=Bing!15706668163
# Docker 环境（已注释）
# DATABASE_URL="postgresql://postgres:Bing!15706668163@host.docker.internal:54321/content-publish"
# 本地开发使用
DATABASE_URL="postgresql://postgres:Bing!15706668163@localhost:54321/content-publish"

# ----- Redis 配置 -----
# 使用外部 Redis（已独立部署）
REDIS_PASSWORD=redis
REDIS_URL="redis://halfthin:redis@host.docker.internal:16378/0"
# 本地开发备用
# REDIS_URL="redis://localhost:6379/0"

# ----- Cookie 加密配置 (生产环境必须修改!) -----
COOKIE_ENCRYPTION_KEY="your-32-char-secret-key-here!!!"
COOKIE_ENCRYPTION_SALT="random-salt-string"

# ----- 服务器配置 -----
PORT=50000
NODE_ENV=development

# ----- WebSocket 配置 -----
WS_HEARTBEAT_INTERVAL=30000
AUTH_TIMEOUT=900000

# ----- 内容目录 -----
CONTENT_DIR="./content"

# ----- 日志级别 -----
LOG_LEVEL="debug"

# ----- Playwright 配置 -----
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_SLOW_MO=100

# ----- Browserless 配置 -----
# CDP 模式端点（Browserless v1.61+）(已注释)
# BROWSERLESS_URL=ws://browserless:3000
# 本地开发使用 (已注释 - 使用本地浏览器)
# BROWSERLESS_URL=ws://localhost:6666
