{
  "name": "content-publish-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "cd apps/server && bun run dev:watch",
    "start": "cd apps/server && bun run start",
    "dev:server": "cd apps/server && bun run start",
    "dev:server:watch": "cd apps/server && bun run dev:watch",
    "build": "cd apps/server && bun run lint",
    "check": "cd apps/server && bun run check",
    "test": "cd apps/server && bun test",
    "db:generate": "cd apps/server && bun run db:generate",
    "db:migrate": "cd apps/server && bun run db:migrate",
    "db:push": "cd apps/server && bun run db:push",
    "docker:up": "docker-compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f docker/docker-compose.yml down"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
