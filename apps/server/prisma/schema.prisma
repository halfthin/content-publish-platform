// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 账号分组
model AccountGroup {
  id          String    @id @default(uuid())
  platform    String    // xiaohongshu, weibo, douyin, bilibili, wechat
  name        String    // A 组、B 组、C 组
  description String?
  accounts    Account[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([platform, name])
  @@index([platform])
}

// 平台账号
model Account {
  id              String       @id @default(uuid())
  platform        String       // xiaohongshu, weibo, douyin, bilibili, wechat
  name            String       // 账号显示名称
  username        String?      // 登录用户名
  groupId         String
  group           AccountGroup @relation(fields: [groupId], references: [id])
  
  // Cookie 加密存储
  encryptedCookies String?     // 加密后的 cookie 数据（字符串格式）
  cookiePassword   String?     // Cookie 加密密码（可选，默认使用全局密钥）
  cookieUpdatedAt  DateTime?   // Cookie 最后更新时间
  
  // Cookie 健康度监控（新增）
  cookieHealthScore  Int?      @default(100)  // Cookie健康度分数 0-100
  lastCookieCheckAt  DateTime?                // 最后检查时间
  cookieExpiryWarning Boolean? @default(false) // 过期预警
  cookieRefreshAttempts Int?   @default(0)    // 刷新尝试次数
  cookieLastRefreshAt DateTime?               // 最后刷新时间
  
  // 账号状态
  status          AccountStatus @default(ACTIVE)
  loginStatus     LoginStatus   @default(UNKNOWN)
  dailyLimit      Int           @default(10)  // 每日发布限制
  todayPublished  Int           @default(0)  // 今日已发布
  lastPublishedAt DateTime?
  
  // 健康度监控
  healthScore     Int           @default(100) // 0-100
  warningFlags    String[]      // 限流、异常等标记
  
  // 元数据
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  publishLogs     PublishLog[]

  @@index([platform, status])
  @@index([groupId])
}

enum AccountStatus {
  ACTIVE      // 正常
  INACTIVE    // 停用
  SUSPENDED   // 暂停使用
  BANNED      // 被封禁
}

enum LoginStatus {
  LOGGED_IN   // 已登录
  EXPIRED     // Cookie 过期
  UNKNOWN     // 未知
  CHECKING    // 检测中
}

// 内容
model Content {
  id              String        @id           // UUID v7
  relativePath    String        @unique       // 如 inbox/笔记12/
  title           String
  status          ContentStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  finishedAt      DateTime?

  publishLogs     PublishLog[]
  publishPlans    PublishPlan[]

  @@index([status, createdAt])
  @@map("contents")
}

model PublishPlan {
  id              String        @id @default(cuid())
  contentId       String
  platform        String
  accountId       String
  title           String?
  scheduledAt     DateTime?
  status          String        @default("PENDING")  // PENDING → PUBLISHING → DONE / FAILED
  errorMessage    String?
  errorCode       String?
  externalTaskId  String?
  publishedUrl    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  finishedAt      DateTime?

  content         Content       @relation(fields: [contentId], references: [id])

  @@index([contentId])
  @@index([contentId, status])
  @@index([status])
  @@map("publish_plans")
}

enum ContentStatus {
  PENDING     // 待审核
  APPROVED    // 已通过
  REJECTED    // 已拒绝
  PUBLISHING  // 发布中
  PUBLISHED   // 已发布
  FAILED      // 发布失败
}

// 发布日志
model PublishLog {
  id          String        @id @default(uuid())
  contentId   String
  content     Content       @relation(fields: [contentId], references: [id])
  publishPlanId String?
  accountId   String
  account     Account       @relation(fields: [accountId], references: [id])
  jobId       String?
  
  platform    String        // 冗余字段，便于查询
  status      PublishStatus @default(PENDING)
  
  // 发布详情
  externalTaskId String?
  publishedUrl String?      // 发布后链接
  errorMessage String?      // 错误信息
  errorCode    String?      // 错误码
  callbackPayload Json?
  retryCount   Int          @default(0)
  maxRetries   Int          @default(3)
  
  // 时间戳
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([contentId])
  @@index([accountId])
  @@index([jobId])
  @@index([externalTaskId])
  @@index([status])
  @@index([createdAt])
}

enum PublishStatus {
  PENDING           // 等待执行
  QUEUED            // 已进入队列
  RUNNING           // 执行中
  NEEDS_AUTH        // 需要人工介入
  USER_INTERVENING  // 用户介入中
  RESUMED           // 已恢复
  SUCCESS           // 成功
  FAILED            // 失败
  CANCELLED         // 已取消
  RETRYING          // 重试中
}

// 系统配置
model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
}
