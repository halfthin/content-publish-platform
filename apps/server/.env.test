# 测试环境配置
NODE_ENV=test

# 数据库配置
DATABASE_URL="postgresql://test_user:test_password@localhost:54322/content_publish_test?schema=public"

# Redis配置
REDIS_URL="redis://localhost:16379"

# 浏览器自动化配置
BROWSERLESS_URL="ws://localhost:6667"
PLAYWRIGHT_HEADLESS=true

# 加密配置
ENCRYPTION_PASSWORD="test-encryption-password-123"

# 日志配置
LOG_LEVEL=info
LOG_FILE=logs/test.log

# API配置
API_PORT=3001
API_HOST=localhost
CORS_ORIGIN=http://localhost:8080

# 文件存储
CONTENT_STORAGE_PATH=./content-test
UPLOAD_MAX_SIZE=10485760 # 10MB

# 测试模式
TEST_MODE=true
SKIP_AUTH=true