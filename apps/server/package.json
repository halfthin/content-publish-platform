{
  "name": "content-publish-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "dev:watch": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:push": "prisma db push --schema=./prisma/schema.prisma",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check . --write",
    "test": "bun test"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@logtape/file": "^2.0.4",
    "@logtape/logtape": "^2.0.4",
    "bullmq": "latest",
    "chromium-bidi": "^15.0.0",
    "cron": "^4.4.0",
    "elysia": "latest",
    "ioredis": "latest",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "1.41.2",
    "zod": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@prisma/client": "5",
    "bun-types": "latest",
    "dotenv": "^17.3.1",
    "pg": "^8.19.0",
    "prisma": "5",
    "typescript": "^5.0"
  }
}
