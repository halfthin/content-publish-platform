# 服务器配置
PORT=50000
NODE_ENV=development

# 数据库配置
DATABASE_URL="postgresql://postgres:postgres@localhost:54321/chujiang?schema=cpp"

# Redis 配置
REDIS_URL="redis://halfthin:change-me@localhost:16378/0"

# Cookie 加密配置
COOKIE_ENCRYPTION_KEY="dev-key-change-in-production-32chars!!"
COOKIE_ENCRYPTION_SALT="dev-salt"

# WebSocket 配置
WS_HEARTBEAT_INTERVAL=30000
AUTH_TIMEOUT=900000

# 内容目录
CONTENT_DIR="./content"
MEDIA_ROOT_LIST="/mnt/dapai-s/REGAL_WOOL[统一存放],/path/to/other1,/path/to/other2"

# 日志级别
LOG_LEVEL="debug"

# Playwright 配置
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOW_MO=100

# ----- HT Queue (外部任务队列) -----
# HT Queue 服务地址，用于提交发布任务和接收回调
HT_QUEUE_BASE_URL=http://100.64.0.6:44200/api

# API 认证
API_AUTH_TOKEN="replace-with-production-api-auth-token"
EXPOSE_DOCS=false

# ----- Xiaohongshu MCP 直连配置 -----
# JSON 数组，每个元素包含 name 和 url，一个实例对应一个小红书账号
XHS_MCP_INSTANCES=[]
RUN_REAL_XHS_TESTS=false
# 真实发布示例：XHS_MCP_INSTANCES=[{"name":"xhs-1","url":"http://100.64.0.11:5601"}]
