# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置
DATABASE_URL="postgresql://postgres:Bing!15706668163@192.168.0.14:15432/content-publish"

# Redis 配置 (BullMQ)
REDIS_URL="redis://localhost:6379/0"

# Cookie 加密配置
COOKIE_ENCRYPTION_KEY="dev-key-change-in-production-32chars!!"
COOKIE_ENCRYPTION_SALT="dev-salt"

# WebSocket 配置
WS_HEARTBEAT_INTERVAL=30000
AUTH_TIMEOUT=900000

# 内容目录
CONTENT_DIR="./content"

# 日志级别
LOG_LEVEL="debug"

# Playwright 配置
# P1: 本地 Playwright 主路径（不填 BROWSERLESS_URL 时生效）
# P3: browserless fallback 路径（填了则走远程 browserless）
# BROWSERLESS_URL=ws://localhost:3000
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOW_MO=100

# ----- OpenClaw Gateway -----
OPENCLAW_GATEWAY_URL=http://localhost:18789
CPP_TO_GATEWAY_TOKEN=your-gateway-token
CPP_FROM_GATEWAY_TOKEN=your-callback-token

# 发布模式: gateway (默认) 或 local
PUBLISH_MODE=gateway

# API 暴露地址 (用于 Gateway 回调)
API_BASE_URL=http://localhost:50000
